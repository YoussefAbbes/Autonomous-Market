# ---------------------------
# Core database configuration
# ---------------------------
POSTGRES_DB=market_intel
POSTGRES_USER=market_user
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# --------------------------------
# n8n security + runtime settings
# --------------------------------
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# ------------------------------------
# ML API model/runtime configuration
# ------------------------------------
ML_API_PORT=8000
ML_API_MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english

# ------------------------------------
# MCP server transport configuration
# ------------------------------------
MCP_PORT=8080
MCP_HOST=0.0.0.0
MCP_TRANSPORT=streamable-http
MCP_PATH=/mcp
